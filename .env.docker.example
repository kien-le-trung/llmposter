# Frontend container
INTERNAL_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend container
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/llmposter
LLM_EXPERIMENT_CONFIG=experiments/model_configs/cpu_model.json
EMBEDDING_MODEL_SERVER_URL=http://model:11434
EMBEDDING_MODEL_NAME=nomic-embed-text
INFERENCE_MODE=remote
AGENT_CONFIG_SOURCE=database
WORD_SELECTION_MODE=random
FIXED_SECRET_WORD=satellite
FIXED_IMPOSTER_HINT=Space, signals, or orbit
