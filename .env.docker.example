# Frontend container
INTERNAL_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend container
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/llmposter
INFERENCE_MODE=remote
LLM_CONFIG={"name":"OpenRouter default","provider":"openrouter","chat_url":"https://openrouter.ai/api/v1/chat/completions","model":"openrouter/free","api_key_env":"OPENROUTER_API_KEY","min_max_tokens":10000,"structured_max_tokens":10000,"max_concurrent_requests":4}
OPENROUTER_API_KEY=
EMBEDDING_MODEL_SERVER_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_MODEL_NAME=gemini-embedding-001
GEMINI_API_KEY=
AGENT_CONFIG_SOURCE=database
WORD_SELECTION_MODE=random
FIXED_SECRET_WORD=satellite
FIXED_IMPOSTER_HINT=orbit
